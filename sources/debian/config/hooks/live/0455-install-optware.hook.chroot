#!/bin/sh

set -e

# Install the optware system
sh /bin/Springbank-bootstrap_1.3-0_x86_64.xsh
rm -f /bin/Springbank-bootstrap_1.3-0_x86_64.xsh

# TFTP server folder
mkdir -p /opt/srv/tftp

# Install our public key
wget http://debian2/meta/calnex_debian.pub
gpg --import ./calnex_debian.pub
rm -f ./calnex_debian.pub
