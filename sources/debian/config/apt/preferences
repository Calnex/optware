# Prioritize security updates above everything else
Package: *
Pin: release a=bullseye-security
Pin-Priority: 999

# Backports at default priority (opt-in per-package unless explicitly overridden)
Package: *
Pin: release a=bullseye-backports
Pin-Priority: 500

# Pull the kernel from backports specifically
Package: linux-image-amd64
Pin: release a=bullseye-backports
Pin-Priority: 1000

# Never install isc-dhcp-client
Package: isc-dhcp-client
Pin: version *
Pin-Priority: -1
